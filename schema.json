{
    "users": {
        "{uid}": {
            "uid": "string",
            "email": "string",
            "nombre": "string",
            "photoURL": "string (optional)",
            "createdAt": "timestamp"
        }
    },
    "bands": {
        "{bandId}": {
            "nombre": "string",
            "ownerId": "string (uid)",
            "inviteCode": "string",
            "customId": "string (short readable ID)",
            "createdAt": "timestamp",
            "members": [
                "string (uid)"
            ],
            "admins": [
                "string (uid)"
            ]
        },
        "subcollections": {
            "musicians": {
                "{uid}": {
                    "uid": "string",
                    "role": "string",
                    "instrument": {
                        "id": "string",
                        "nombre": "string"
                    },
                    "joinedAt": "timestamp",
                    "bandId": "string"
                }
            },
            "songs": {
                "{songId}": {
                    "customId": "string (optional)",
                    "titulo": "string",
                    "tonalidad": "string",
                    "letraCruda": "string (Lyrics with Chords above - UltimateGuitar style)",
                    "acordesExtra": "string (Optional raw tabs or notes)",
                    "old_chordProContent": "string (Legacy, kept for backwards compatibility)",
                    "old_letra": "string (Legacy)",
                    "old_acordes": "string (Legacy)",
                    "duracion": "number (seconds)",
                    "createdAt": "timestamp",
                    "updatedAt": "timestamp",
                    "bandId": "string"
                }
            },
            "rehearsals": {
                "{rehearsalId}": {
                    "customId": "string",
                    "fecha": "date string (YYYY-MM-DD)",
                    "notas": "string",
                    "asistentes": [
                        "string (uid)"
                    ],
                    "createdAt": "timestamp",
                    "bandId": "string"
                }
            },
            "finances": {
                "{financeId}": {
                    "customId": "string",
                    "tipo": "string (ingreso/egreso)",
                    "monto": "number",
                    "fecha": "date string",
                    "descripcion": "string",
                    "registradoPor": "string (uid)",
                    "createdAt": "timestamp",
                    "bandId": "string"
                }
            },
            "gear": {
                "{gearId}": {
                    "customId": "string",
                    "name": "string",
                    "tipo": "string",
                    "estado": "string",
                    "propietario": "string (uid or band)",
                    "createdAt": "timestamp",
                    "bandId": "string"
                }
            },
            "gigs": {
                "{gigId}": {
                    "customId": "string",
                    "fecha": "date string",
                    "lugar": "string",
                    "pago": "number",
                    "setlist": [
                        "string (songId)"
                    ],
                    "createdAt": "timestamp",
                    "bandId": "string"
                }
            }
        }
    }
}