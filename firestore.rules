rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función para verificar si el usuario es miembro de la banda
    function isMember(bandId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/bands/$(bandId)/musicians/$(request.auth.uid));
    }

    // Función para obtener el rol del usuario
    function getRole(bandId) {
      return get(/databases/$(database)/documents/bands/$(bandId)/musicians/$(request.auth.uid)).data.role;
    }

    function isAdmin(bandId) {
      return (isMember(bandId) && getRole(bandId) == 'Administrador') || 
             (isAuthenticated() && get(/databases/$(database)/documents/bands/$(bandId)).data.ownerId == request.auth.uid);
    }

    function isEditor(bandId) {
      return isAdmin(bandId) || (isMember(bandId) && getRole(bandId) == 'Editor');
    }

    function isVisor(bandId) {
      return isMember(bandId);
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == 'josimaromahn@gmail.com';
    }

    // Usuarios: Solo el dueño puede leer/escribir su perfil, o Devs pueden listar todos
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (
        request.auth.uid == userId || isSuperAdmin()
      );
    }

    // Bandas: 
    match /bands/{bandId} {
      // Cualquier usuario autenticado puede crear una banda
      allow create: if isAuthenticated();
      
      // Permite GET si: eres miembro, eres SuperAdmin, o tienes una invitación pendiente por email.
      allow get: if isAuthenticated() && (
        isMember(bandId) || 
        isSuperAdmin() || 
        exists(/databases/$(database)/documents/bands/$(bandId)/invitations/$(request.auth.token.email.lower()))
      );
      
      // LIST: Se permite listar si soy miembro, si soy SuperAdmin, o si estoy consultando con limit(1) (para el inviteCode)
      allow list: if isAuthenticated() && (
        (request.auth.uid in resource.data.members) ||
        (request.query.limit <= 1) ||
        isSuperAdmin()
      );

      allow delete: if isSuperAdmin();

      // Solo Admins pueden actualizar la banda (nombre, configuración)
      allow update: if isAdmin(bandId);
      
      // Finances: Solo Administradores
      match /finances/{docId} {
        allow read, write: if isAdmin(bandId) || isSuperAdmin();
      }

      // Musicians: 
      match /musicians/{memberId} {
        allow read: if isVisor(bandId) || isSuperAdmin();
        allow create: if isAuthenticated() && request.auth.uid == memberId;
        allow update: if isAdmin(bandId) || (request.auth.uid == memberId && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])));
        allow delete: if isAdmin(bandId) || isSuperAdmin();
      }

      // Generic Content (Songs, Gigs, Gear, Rehearsals)
      match /songs/{documentId} { allow read: if isVisor(bandId); allow write: if isEditor(bandId) || isSuperAdmin(); }
      match /gigs/{documentId} { allow read: if isVisor(bandId); allow write: if isEditor(bandId) || isSuperAdmin(); }
      match /gear/{documentId} { allow read: if isVisor(bandId); allow write: if isEditor(bandId) || isSuperAdmin(); }
      match /rehearsals/{documentId} { allow read: if isVisor(bandId); allow write: if isEditor(bandId) || isSuperAdmin(); }
      match /instruments/{documentId} { allow read: if isVisor(bandId); allow write: if isEditor(bandId) || isSuperAdmin(); }

      // Sistema de Comentarios (Refactorizado a authorUid)
      match /comments/{commentId} {
        allow read: if isMember(bandId) || isSuperAdmin();
        allow create: if isMember(bandId) && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if (isMember(bandId) && (resource.data.authorUid == request.auth.uid || isAdmin(bandId))) || isSuperAdmin();
      }

      // Sistema de Invitaciones Personalizadas
      match /invitations/{email} {
        allow create, update, delete: if isAdmin(bandId) || isSuperAdmin();
        allow read: if isAdmin(bandId) || isSuperAdmin() || (isAuthenticated() && request.auth.token.email.lower() == email.lower());
      }
    }

    // System Settings (Feature Flags) - Global
    match /system_settings/{docId} {
      allow read: if true; // All users (including visitors) need to read flags (e.g. maintenance mode)
      allow write: if isSuperAdmin();
    }
  }
}

