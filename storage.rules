rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    
    // Función para verificar si un usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Regla base para proteger todos los archivos subidos al sistema
    match /bands/{bandId}/{allPaths=**} {
      // Función auxiliar para verificar membresía desde Storage
      function isMember(bandId) {
        return request.auth != null && 
          firestore.exists(/databases/(default)/documents/bands/$(bandId)/musicians/$(request.auth.uid));
      }

      // Las lecturas son permitidas SOLO a miembros de la banda (o SuperAdmins vía email)
      allow read: if isMember(bandId) || (request.auth != null && request.auth.token.email == 'josimaromahn@gmail.com'); 
      
      // La subida y escritura es estricta: Solo miembros + Max 2MB + Solo JPG y PDF
      allow write: if isMember(bandId)
                   && request.resource.size < 2 * 1024 * 1024 // 2 Megabytes
                   && request.resource.contentType.matches('application/pdf|image/jpeg|image/jpg');
    }
  }
}
